# Supabase (Auth only; database is Netlify Neon — see below)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Database: Netlify DB (built-in Neon Postgres).
# - On Netlify production builds NETLIFY_DATABASE_URL is injected automatically
#   once a database is connected from the Netlify dashboard. No action needed.
# - For local development:
#     `netlify dev` will inject NETLIFY_DATABASE_URL automatically, OR
#     set DATABASE_URL below to any Neon connection string.
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
